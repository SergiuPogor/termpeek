{
  "name": "termpeek",
  "version": "1.0.0",
  "description": "Beautiful SVG visualizations for git repositories — contribution heatmaps, repo cards, language donuts, and more",
  "keywords": [
    "git",
    "svg",
    "visualization",
    "contributions",
    "heatmap",
    "github",
    "readme",
    "badge",
    "repo-stats",
    "terminal"
  ],
  "license": "MIT",
  "author": "Serghei Pogor <serghei.pogor@gmail.com> (https://github.com/SergiuPogor)",
  "homepage": "https://github.com/SergiuPogor/termpeek",
  "repository": {
    "type": "git",
    "url": "https://github.com/SergiuPogor/termpeek.git"
  },
  "type": "module",
  "bin": {
    "termpeek": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint src --ext .ts",
    "fix": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
